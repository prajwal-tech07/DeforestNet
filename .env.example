# ============================================================
# DeforestNet - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ==================== NOTIFICATIONS ====================

# Telegram Bot (FREE - Get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Email (FREE - Gmail App Password)
EMAIL_SENDER=musicapp9880@gmail.com
EMAIL_PASSWORD=Musicapp@1234
NOTIFICATION_RECIPIENT_EMAIL=musicapp9880@gmail.com

# Firebase (FREE tier - Optional)
# Create a project at https://console.firebase.google.com
# Download service account key and save as configs/firebase_credentials.json
FIREBASE_ENABLED=false

# ==================== DATABASE ====================
DATABASE_PATH=database/deforestnet.db

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=true

# ==================== MODEL ====================
MODEL_CHECKPOINT=models/checkpoints/best_model.pth

# ==================== LOGGING ====================
LOG_LEVEL=INFO
